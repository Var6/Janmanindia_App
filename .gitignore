# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# privileged seeds (director + administrator only — keep out of git)
/scripts/seed-privileged.mjs

# real-team seed — contains real names, phones, role mappings; never commit
/scripts/seed-team.mjs

# local-only credentials cheatsheet — keep on developer machines, never commit
/CREDENTIALS.txt

# uploaded files — local-FS dev fallback only; production uses Vercel Blob
/public/uploads/*
!/public/uploads/.gitkeep
