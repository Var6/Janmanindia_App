# Copy to .env.local (never commit) and fill before `npm run dev`.

# MongoDB connection string — local for dev, Atlas for prod
MONGODB_URI=mongodb://localhost:27017/janman

# JWT signing secret — must be at least 32 characters
# Generate one with: openssl rand -hex 48
JWT_SECRET=

# Public URL of the app — used by the logout redirect
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional integrations — leave blank to disable

# Vercel Blob (auto-set by Vercel when a Blob store is connected)
# BLOB_READ_WRITE_TOKEN=

# Google Calendar (single-line service-account JSON + calendar id)
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_CALENDAR_ID=primary

# Airtable mirror
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=

# OCR service
# OCR_SERVICE_KEY=
